{
  "info": {
    "name": "Reto Backend - Microservicios Bancarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "customerBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "accountBaseUrl",
      "value": "http://localhost:8082"
    }
  ],
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{customerBaseUrl}}/clientes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"CLI-001\",\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 32,\n  \"identificacion\": \"0102030405\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"0987654321\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            }
          }
        },
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "url": "{{customerBaseUrl}}/clientes"
          }
        }
      ]
    },
    {
      "name": "Cuentas y movimientos",
      "item": [
        {
          "name": "Crear cuenta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/cuentas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorros\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": \"CLI-001\",\n  \"clienteNombre\": \"Jose Lema\"\n}"
            }
          }
        },
        {
          "name": "Registrar deposito",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/movimientos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"valor\": 600\n}"
            }
          }
        },
        {
          "name": "Retiro sin saldo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/movimientos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"valor\": -999999\n}"
            }
          }
        },
        {
          "name": "Reporte",
          "request": {
            "method": "GET",
            "url": "{{accountBaseUrl}}/reportes?fecha=2026-01-01,2026-12-31&cliente=CLI-001"
          }
        }
      ]
    }
  ]
}
