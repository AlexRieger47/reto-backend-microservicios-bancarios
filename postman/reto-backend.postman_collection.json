{
  "info": {
    "name": "Reto Backend - Microservicios Bancarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "customerBaseUrl",
      "value": "http://127.0.0.1:8081"
    },
    {
      "key": "accountBaseUrl",
      "value": "http://127.0.0.1:8082"
    },
    {
      "key": "movementId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{customerBaseUrl}}/clientes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"CLI-001\",\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 32,\n  \"identificacion\": \"0102030405\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"0987654321\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            }
          }
        },
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "url": "{{customerBaseUrl}}/clientes"
          }
        }
      ]
    },
    {
      "name": "Cuentas y movimientos",
      "item": [
        {
          "name": "Crear cuenta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/cuentas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorros\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": \"CLI-001\",\n  \"clienteNombre\": \"Jose Lema\"\n}"
            }
          }
        },
        {
          "name": "Registrar deposito",
          "description": "Ejecutar antes de consultar o actualizar movimiento. Este request guarda automaticamente `movementId` con el ID del movimiento creado.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/movimientos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"valor\": 600\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('movementId', body.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Consultar movimiento por ID",
          "description": "Usa `{{movementId}}`, variable que se carga al ejecutar primero `Registrar deposito`. Si se ejecuta aislado, reemplazarla por un ID real existente.",
          "request": {
            "method": "GET",
            "url": "{{accountBaseUrl}}/movimientos/{{movementId}}"
          }
        },
        {
          "name": "Actualizar movimiento",
          "description": "Usa `{{movementId}}`, variable que se carga al ejecutar primero `Registrar deposito`. Si se ejecuta aislado, reemplazarla por un ID real existente.",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/movimientos/{{movementId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"valor\": 800\n}"
            }
          }
        },
        {
          "name": "Retiro sin saldo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{accountBaseUrl}}/movimientos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"valor\": -999999\n}"
            }
          }
        },
        {
          "name": "Reporte",
          "request": {
            "method": "GET",
            "url": "{{accountBaseUrl}}/reportes?fecha=2026-01-01,2026-12-31&cliente=CLI-001"
          }
        }
      ]
    }
  ]
}
